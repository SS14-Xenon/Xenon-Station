### Popups
reactor-smoke-start = {$owner} начинает дымить!
reactor-smoke-stop = {$owner} перестаёт дымить.
reactor-fire-start = {$owner} загорается!
reactor-fire-stop = {$owner} перестаёт гореть.

reactor-unanchor-melted = Нельзя открепить ядерный реактор — он расплавился в корпус!
reactor-unanchor-warning = Нельзя открепить ядерный реактор, пока он не пуст или его температура выше 80°C!
reactor-anchor-warning = Недопустимая позиция для закрепления.

### Messages
reactor-smoke-start-message = ОПАСНОСТЬ!: {$owner} НА ОПАСНОЙ РАБОЧЕЙ ТЕМПЕРАТУРЕ! РАБОЧАЯ ТЕМПЕРАТУРА: {$temperature} K. ТРЕБУЕТСЯ НЕМЕДЛЕННОЕ ВМЕШАТЕЛЬСТВО!
reactor-smoke-stop-message = {$owner} вернулся к номинальной рабочей температуре.
reactor-fire-start-message = ВНИМАНИЕ! ВНИМАНИЕ!: {$owner} В КРИТИЧЕСКОМ РЕЖИМЕ! РАБОЧАЯ ТЕМПЕРАТУРА: {$temperature} K. РАСПЛАВ АКТИВНОЙ ЗОНЫ НЕИЗБЕЖЕН!
reactor-fire-stop-message = {$owner} вернулся к номинальной рабочей температуре. Расплав активной зоны предотвращён.

reactor-temperature-dangerous-message = {$owner} на опасной температуре: {$temperature} K.
reactor-temperature-critical-message = {$owner} на критической температуре: {$temperature} K.
reactor-temperature-cooling-message = {$owner} остывает: {$temperature} K.

reactor-melting-announcement = УГРОЗА РАСПЛАВА ЯДЕРНОГО РЕАКТОРА! РЕКОМЕНДУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
reactor-melting-announcement-sender = ЯДЕРНАЯ АВАРИЯ

reactor-meltdown-announcement = НАЧАЛСЯ РАСПЛАВ ЯДЕРНОГО РЕАКТОРА! ТРЕБУЕТСЯ НЕМЕДЛЕННАЯ ЭВАКУАЦИЯ!
reactor-meltdown-announcement-sender = ЯДЕРНЫЙ РАСПЛАВ

